# Copy this file to .env and fill in real values. Never commit .env to git.

# Supabase / PostgreSQL connection string
SQLALCHEMY_DATABASE_URI=postgresql://user:password@host:5432/database

# Flask JWT signing secret — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Gmail (or SMTP) credentials for password-reset emails
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-app-password

# Supabase Storage — get from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_API=your-supabase-anon-key
# Name of the storage bucket used for uploads (Project Settings → Storage).
# Must have public read access enabled — feed/ad images are served as direct
# public URLs, not proxied through the backend. If unset, the app falls back
# to whichever bucket list_buckets() returns first.
SUPABASE_BUCKET=your-bucket-name

# YouTube Data API v3 key — powers the SuperAdmin "YouTube channels" monitor
# (content-pipeline/youtube/*). Get one from Google Cloud Console:
#   console.cloud.google.com → create/select a project → APIs & Services →
#   Enable "YouTube Data API v3" → Credentials → Create credentials → API key.
# The channel add/list/remove routes are pure DB ops, but the "check for new
# uploads" route returns 503 until this is set. Leave blank to disable.
YOUTUBE_API_KEY=

# Comma-separated list of frontend origins allowed by CORS (no trailing slashes)
# Include every domain the frontend is served from
FRONTEND_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000
